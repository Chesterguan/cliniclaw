# ClinicClaw Environment Variables
# Copy to .env and fill in values

# Mock mode — set to true for demo (no external deps needed)
CLINICLAW_MOCK=true

# API server
LISTEN_ADDR=0.0.0.0:3000

# FHIR backend (not needed in mock mode)
# FHIR_BASE_URL=http://localhost:8103/fhir/R4
# FHIR_TOKEN=your-fhir-token

# Claude API (not needed in mock mode)
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Audit store
DATABASE_URL=sqlite:cliniclaw.sqlite

# Logging
RUST_LOG=cliniclaw=info,tower_http=info
